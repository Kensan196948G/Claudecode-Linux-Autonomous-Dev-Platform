{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeCode DevOS state.json",
  "type": "object",
  "required": [
    "system",
    "goal",
    "kpi",
    "execution",
    "automation",
    "limits",
    "usage",
    "resources",
    "claude",
    "projects",
    "github",
    "decision",
    "ci",
    "risk",
    "scheduler",
    "projects_runtime",
    "dashboard",
    "control",
    "worktree",
    "history",
    "strategy"
  ],
  "properties": {
    "system": {
      "type": "object",
      "required": ["status", "mode", "health", "recovery_count"],
      "properties": {
        "status": {"type": "string"},
        "mode": {"type": "string"},
        "health": {"type": "string"},
        "last_error": {"type": ["string", "null"]},
        "recovery_count": {"type": "integer"}
      }
    },
    "usage": {
      "type": "object",
      "required": ["daily_seconds_used", "daily_limit_seconds", "weekly_seconds_used", "weekly_limit_seconds"],
      "properties": {
        "daily_seconds_used": {"type": "integer", "minimum": 0},
        "daily_limit_seconds": {"type": "integer", "minimum": 1},
        "weekly_seconds_used": {"type": "integer", "minimum": 0},
        "weekly_limit_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "decision": {
      "type": "object",
      "required": ["current_mode", "next_action"],
      "properties": {
        "current_mode": {"type": "string"},
        "next_action": {"enum": ["idle", "develop", "verify", "repair_ci", "cooldown", "suspend"]},
        "reason": {"type": ["string", "null"]}
      }
    },
    "ci": {
      "type": "object",
      "required": ["repair_attempt_count", "repair_attempt_limit", "auto_merge_enabled", "merge_policy"],
      "properties": {
        "repair_attempt_count": {"type": "integer", "minimum": 0},
        "repair_attempt_limit": {"type": "integer", "minimum": 1, "maximum": 15},
        "auto_merge_enabled": {"type": "boolean"},
        "merge_policy": {"type": "string"},
        "stable": {"type": "boolean"},
        "stable_success_count": {"type": "integer", "minimum": 0},
        "required_stable_successes": {"type": "integer", "minimum": 1, "maximum": 15},
        "stable_blockers": {"type": "array", "items": {"type": "string"}},
        "local_test_status": {"type": ["string", "null"]},
        "lint_status": {"type": ["string", "null"]},
        "build_status": {"type": ["string", "null"]},
        "security_status": {"type": ["string", "null"]},
        "codex_review_status": {"type": ["string", "null"]},
        "error_count": {"type": "integer", "minimum": 0}
      }
    },
    "goal": {
      "type": "object",
      "properties": {
        "title": {"type": "string"},
        "description": {"type": ["string", "null"]},
        "defined": {"type": "boolean"}
      }
    },
    "kpi": {
      "type": "object",
      "properties": {
        "success_rate_target": {"type": "number"},
        "current_success_rate": {"type": ["number", "null"]},
        "status": {"type": "string"},
        "last_evaluated_at": {"type": ["string", "null"]}
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "max_duration_minutes": {"type": "integer", "minimum": 1},
        "remaining_seconds": {"type": "integer", "minimum": 0},
        "time_phase": {"type": "string"}
      }
    },
    "automation": {
      "type": "object",
      "properties": {
        "auto_issue_generation": {"type": "boolean"},
        "self_evolution": {"type": "boolean"},
        "issue_factory_last_run_at": {"type": ["string", "null"]}
      }
    },
    "codex": {
      "type": "object",
      "properties": {
        "available": {"type": "boolean"},
        "setup_status": {"type": ["string", "null"]},
        "plugin": {"type": ["string", "null"]},
        "plugin_installed": {"type": ["boolean", "null"]},
        "plugin_root": {"type": ["string", "null"]},
        "plugin_state_file": {"type": ["string", "null"]},
        "plugin_job_id": {"type": ["string", "null"]},
        "plugin_job_status": {"type": ["string", "null"]},
        "last_result_source": {"type": ["string", "null"]},
        "last_result_file": {"type": ["string", "null"]},
        "review_status": {"type": ["string", "null"]},
        "review_verdict": {"type": ["string", "null"]},
        "review_summary": {"type": ["string", "null"]},
        "review_reason": {"type": ["string", "null"]}
      }
    },
    "github": {
      "type": "object",
      "properties": {
        "auto_merge_enabled": {"type": "boolean"},
        "base_branch": {"type": "string"}
      }
    },
    "control": {
      "type": "object",
      "required": ["manual_override"],
      "properties": {
        "manual_override": {"type": "boolean"},
        "manual_action": {"type": ["string", "null"]}
      }
    },
    "strategy": {
      "type": "object",
      "required": ["enabled", "mode", "weights"],
      "properties": {
        "enabled": {"type": "boolean"},
        "mode": {"enum": ["balanced", "growth", "safe", "finish-fast"]},
        "current_top_project": {"type": ["string", "null"]},
        "weights": {"type": "object"}
      }
    }
  }
}
