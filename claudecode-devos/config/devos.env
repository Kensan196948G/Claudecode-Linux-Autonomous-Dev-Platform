# Base
export DEVOS_HOME="${DEVOS_HOME:-/opt/claudecode-devos}"
export DEVOS_LOG_DIR="${DEVOS_LOG_DIR:-$DEVOS_HOME/runtime/logs}"
export DEVOS_PID_DIR="${DEVOS_PID_DIR:-$DEVOS_HOME/runtime/pids}"
export DEVOS_TMP_DIR="${DEVOS_TMP_DIR:-$DEVOS_HOME/runtime/tmp}"
export DEVOS_METRICS_DIR="${DEVOS_METRICS_DIR:-$DEVOS_HOME/runtime/metrics}"
export DEVOS_STATE_FILE="${DEVOS_STATE_FILE:-$DEVOS_HOME/config/state.json}"
export DEVOS_PROJECTS_FILE="${DEVOS_PROJECTS_FILE:-$DEVOS_HOME/config/projects.json}"
export DEVOS_LOCK_DIR="${DEVOS_LOCK_DIR:-$DEVOS_HOME/runtime/tmp}"

# Claude
export PATH="/home/kensan/.local/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"
export CLAUDE_CMD="${CLAUDE_CMD:-/home/kensan/.local/bin/claude}"
export CLAUDE_OPTIONS="${CLAUDE_OPTIONS:---dangerously-skip-permissions}"
export CLAUDE_MEMORY_LIMIT_KB="${CLAUDE_MEMORY_LIMIT_KB:-20000000}"
export CLAUDE_NICE="${CLAUDE_NICE:-10}"
export CLAUDE_IONICE_CLASS="${CLAUDE_IONICE_CLASS:-2}"
export CLAUDE_IONICE_PRIO="${CLAUDE_IONICE_PRIO:-7}"
export CLAUDE_OOM_SCORE_ADJ="${CLAUDE_OOM_SCORE_ADJ:-500}"
export DEVOS_AUTO_RESTART_CLAUDE="${DEVOS_AUTO_RESTART_CLAUDE:-true}"

# Runtime limits
export SESSION_MAX_SECONDS="${SESSION_MAX_SECONDS:-18000}"
export WEEKLY_LIMIT_SECONDS="${WEEKLY_LIMIT_SECONDS:-90000}"
export PROJECT_TERM_DAYS="${PROJECT_TERM_DAYS:-183}"
export MAX_PARALLEL_PROJECTS="${MAX_PARALLEL_PROJECTS:-1}"

# Thresholds
export MIN_FREE_MB="${MIN_FREE_MB:-3000}"
export MAX_SWAP_USED_MB="${MAX_SWAP_USED_MB:-1000}"
export MAX_CPU_PERCENT="${MAX_CPU_PERCENT:-85}"
export MAX_LOADAVG="${MAX_LOADAVG:-3.0}"
export DISK_ALERT_PERCENT="${DISK_ALERT_PERCENT:-90}"

# Notification (optional)
export ALERT_MAIL_TO="${ALERT_MAIL_TO:-}"
export ALERT_MAIL_ENABLED="${ALERT_MAIL_ENABLED:-false}"

# GitHub automation
export GITHUB_BASE_BRANCH="${GITHUB_BASE_BRANCH:-main}"
export GITHUB_ISSUE_LIMIT="${GITHUB_ISSUE_LIMIT:-5}"
export GITHUB_AUTO_MERGE="${GITHUB_AUTO_MERGE:-false}"
export GITHUB_CI_WAIT_SECONDS="${GITHUB_CI_WAIT_SECONDS:-60}"
export GITHUB_LOOP_SLEEP_SECONDS="${GITHUB_LOOP_SLEEP_SECONDS:-600}"
export GITHUB_LOOP_ONCE="${GITHUB_LOOP_ONCE:-false}"

# Decision / CI repair
export DECISION_COOLDOWN_SECONDS="${DECISION_COOLDOWN_SECONDS:-900}"
export CI_REPAIR_TIMEOUT_SECONDS="${CI_REPAIR_TIMEOUT_SECONDS:-7200}"
export CI_REPAIR_ATTEMPT_LIMIT="${CI_REPAIR_ATTEMPT_LIMIT:-15}"
export CI_AUTO_MERGE="${CI_AUTO_MERGE:-false}"
export AUTO_DEV_TIMEOUT_SECONDS="${AUTO_DEV_TIMEOUT_SECONDS:-$SESSION_MAX_SECONDS}"
export STABLE_REQUIRED_SUCCESSES="${STABLE_REQUIRED_SUCCESSES:-3}"
export GITHUB_AUTO_ISSUE_GENERATION="${GITHUB_AUTO_ISSUE_GENERATION:-false}"
export ISSUE_FACTORY_CREATE_LIMIT="${ISSUE_FACTORY_CREATE_LIMIT:-3}"
export DEVOS_QUALITY_TIMEOUT_SECONDS="${DEVOS_QUALITY_TIMEOUT_SECONDS:-900}"
export DEVOS_ENABLE_QUALITY_CHECKS="${DEVOS_ENABLE_QUALITY_CHECKS:-true}"
export DEVOS_CLAUDE_HOME="${DEVOS_CLAUDE_HOME:-$HOME/.claude}"
export DEVOS_GLOBAL_CLAUDEOS_SYNC="${DEVOS_GLOBAL_CLAUDEOS_SYNC:-true}"
export PROMPT_DOCS_MAX_BYTES="${PROMPT_DOCS_MAX_BYTES:-12000}"
export ISSUE_PRIORITY_LIMIT="${ISSUE_PRIORITY_LIMIT:-20}"
export WORKTREE_ENABLED="${WORKTREE_ENABLED:-true}"
export WORKTREE_BASE_DIR="${WORKTREE_BASE_DIR:-$DEVOS_HOME/runtime/worktrees}"
export DEVOS_TERMINAL_CMD="${DEVOS_TERMINAL_CMD:-}"
export DEVOS_WINDOWS_TERMINAL_SSH_TARGET="${DEVOS_WINDOWS_TERMINAL_SSH_TARGET:-kensan@192.168.0.143}"
export DEVOS_LINUX_SSH_TARGET="${DEVOS_LINUX_SSH_TARGET:-kensan@192.168.0.185}"
export DEVOS_REPORT_DIR="${DEVOS_REPORT_DIR:-$DEVOS_HOME/reports}"
export DEVOS_EVOLUTION_LOG_FILE="${DEVOS_EVOLUTION_LOG_FILE:-$DEVOS_HOME/runtime/evolution/logs/execution_log.json}"
export DEVOS_EVOLUTION_METRICS_FILE="${DEVOS_EVOLUTION_METRICS_FILE:-$DEVOS_HOME/runtime/evolution/metrics/latest_metrics.json}"
export DEVOS_EVOLUTION_PROMPT_FILE="${DEVOS_EVOLUTION_PROMPT_FILE:-$DEVOS_HOME/runtime/prompts/evolution_instructions.md}"
export CLUSTER_STATE_FILE="${CLUSTER_STATE_FILE:-$DEVOS_HOME/cluster/controller/cluster_state.json}"
export CLUSTER_WORKER_CONFIG="${CLUSTER_WORKER_CONFIG:-$DEVOS_HOME/cluster/workers/worker_config.json}"
export CLUSTER_SYNC_ENABLED="${CLUSTER_SYNC_ENABLED:-false}"
export CLUSTER_DEFAULT_USER="${CLUSTER_DEFAULT_USER:-kensan}"
export CLUSTER_CONTROLLER_ID="${CLUSTER_CONTROLLER_ID:-$(hostname)}"
export CLUSTER_JOB_RETRY_LIMIT="${CLUSTER_JOB_RETRY_LIMIT:-3}"
export STRATEGY_SCORES_FILE="${STRATEGY_SCORES_FILE:-$DEVOS_HOME/strategy/scores/latest_scores.json}"
export STRATEGY_HISTORY_FILE="${STRATEGY_HISTORY_FILE:-$DEVOS_HOME/strategy/history/selection_history.json}"
export LOG_RETENTION_DAYS="${LOG_RETENTION_DAYS:-7}"
export ARCHIVE_RETENTION_DAYS="${ARCHIVE_RETENTION_DAYS:-30}"
export DEVOS_LOG_ARCHIVE_DIR="${DEVOS_LOG_ARCHIVE_DIR:-$DEVOS_HOME/runtime/archive/logs}"

# Archive
export ARCHIVE_ROOT="${ARCHIVE_ROOT:-/mnt/LinuxHDD/Archive}"

# User / shell
export DEFAULT_SHELL="${DEFAULT_SHELL:-/bin/bash}"
